generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id            String    @id @default(uuid())
  nom           String
  prenom        String
  email         String    @unique
  motDePasse    String
  telephone     String?
  dateNaissance DateTime?
  cni           String?   @unique
  cniRecto      String?
  cniVerso      String?
  demandes      Demande[]
  createdAt     DateTime  @default(now())
}

model AdminMairie {
  id         String   @id @default(uuid())
  nom        String
  prenom     String
  codeUnique String   @unique
  motDePasse String
  role       String   @default("gestionnaire")
  createdAt  DateTime @default(now())
}

model Demande {
  id                String      @id @default(uuid())
  codeUnique        String      @unique
  utilisateurId     String
  utilisateur       Utilisateur @relation(fields: [utilisateurId], references: [id])
  typeActe          String
  statut            String      @default("EN_ATTENTE")
  donnees           Json
  raisonRejet       String?
  dateRendezVous    DateTime?
  dateDisponibilite DateTime?
  verificationIA    Json?
  codeRecuperation  String?     @unique
  dateConfirmation  DateTime?
  documents         Document[]
  rendezVous        RendezVous?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model RendezVous {
  id               String   @id @default(uuid())
  demandeId        String   @unique
  demande          Demande  @relation(fields: [demandeId], references: [id])
  dateRendezVous   DateTime
  codeRecuperation String   @unique
  statut           String   @default("FIXE")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Document {
  id        String  @id @default(uuid())
  demandeId String
  demande   Demande @relation(fields: [demandeId], references: [id])
  nom       String
  url       String
  type      String
}
